#include<stdio.h>
int primecheck(int n){
    int i;
    if (n<=1)
   return 0;
  else{
    for(i = 2;i<n;i++){
      if(n%i==0){
        return 0;
        
      }
    }
    return 1;
  }
}
int main(){
    int n;
    printf("enter the number");
    scanf("%d",&n);
    if (primecheck(n)){
    printf("prime");}
    else{
    printf("not prime");}
    return 0;}