#include<stdio.h>

int main(){
    int a[10][10], b[10][10], c[10][10];
    int i, j, r, col;
    
    printf("Enter rows and columns: ");
    scanf("%d %d", &r, &col);
    printf("Enter elements of Matrix A:\n");
    for(i=0; i<r; i++){
        for(j=0; j<col; j++){
            scanf("%d", &a[i][j]); 
        }
    }
    printf("Enter elements of Matrix B:\n");
    for(i=0; i<r; i++){
        for(j=0; j<col; j++){
            scanf("%d", &b[i][j]); 
        }
    }
    printf("Resultant Matrix C:\n");
    for(i=0; i<r; i++){
        for(j=0; j<col; j++){
            c[i][j] = a[i][j] * b[i][j];
            printf("%d ", c[i][j]); // Har element ke baad space
        }
        printf("\n"); 
    }
    
    return 0;
}
